# Copy to .env (git-ignored) and fill in. NEVER commit real secrets.
# NOTE: v1's Telegram bot token + Groq API key were committed to v1's git history —
# they must be ROTATED (revoked + reissued), not just moved. Put the NEW values here.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
GROQ_API_KEY=

# Per-machine MT5 Files folder (overrides config.yaml execution.queue_dir).
# Windows VPS example (find yours: MT5 -> File -> Open Data Folder -> MQL5 -> Files):
# QUEUE_DIR=C:\Users\Administrator\AppData\Roaming\MetaQuotes\Terminal\<HASH>\MQL5\Files
QUEUE_DIR=
